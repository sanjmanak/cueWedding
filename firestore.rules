rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User documents: users can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Wedding documents: only linked owners can read/write
    match /weddings/{weddingId} {
      allow read, write: if request.auth != null
        && request.auth.uid in resource.data.meta.ownerUids;

      // Allow create if the user is setting themselves as owner
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.meta.ownerUids;
    }

    // Admin override: users with admin role can read/write all weddings
    // (Checked via custom claims in production — for now, use the Firebase console)
    match /weddings/{weddingId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
