rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Development rules: any authenticated user can read/write.
    // TODO: Tighten these before production launch:
    //   - Users should only read/write their own doc
    //   - Couples should only access their own wedding
    //   - Admins get broader access via role check
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
