rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ───── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Role = 'admin' on the user's own users/{uid} doc. Role field is
    // protected below: couples can't self-promote, only existing admins
    // (or a human editing Firestore console) can set role = 'admin'.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isWeddingOwner() {
      return isSignedIn()
        && request.auth.uid in resource.data.meta.ownerUids;
    }

    // Used to let a newly-signed-in bride/groom claim their own wedding
    // when the admin pre-created it with their email but they aren't yet
    // in ownerUids. Stored emails are lowercased at write time
    // (see CreateWedding.jsx) and Firebase stores auth token emails
    // lowercased for email-link / Google auth.
    function emailMatchesCouple() {
      return isSignedIn()
        && request.auth.token.email != null
        && (
          resource.data.meta.brideEmail == request.auth.token.email
          || resource.data.meta.groomEmail == request.auth.token.email
        );
    }

    // ───── users/{uid} ──────────────────────────────────────────────────
    // A user reads/writes only their own doc. Admins can read any user doc
    // (for future admin tooling). Role is protected on create (must be
    // non-admin) and on update (must match existing value) so couples
    // can't promote themselves.
    match /users/{uid} {
      allow read: if (isSignedIn() && request.auth.uid == uid) || isAdmin();

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role != 'admin';

      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.role == resource.data.role);

      allow delete: if isAdmin();
    }

    // ───── weddings/{id} ────────────────────────────────────────────────
    match /weddings/{weddingId} {
      // Reads: owners, admins, and email-matched couples (claim flow).
      allow read: if isAdmin() || isWeddingOwner() || emailMatchesCouple();

      // Create: admins create any wedding. A signed-in user may create a
      // wedding for themselves iff they list themselves as an owner —
      // this supports the "blank wedding fallback" in AuthContext.
      allow create: if isAdmin()
        || (isSignedIn()
            && request.auth.uid in request.resource.data.meta.ownerUids);

      // Update paths:
      //   · admins: anything.
      //   · owners: formData + benign meta, but NOT ownerUids, brideEmail,
      //     or groomEmail (those are admin-controlled to prevent takeover).
      //   · email-matched couples: may only ADD themselves to ownerUids.
      allow update: if isAdmin()
        || (isWeddingOwner()
            && request.resource.data.meta.ownerUids == resource.data.meta.ownerUids
            && request.resource.data.meta.brideEmail == resource.data.meta.brideEmail
            && request.resource.data.meta.groomEmail == resource.data.meta.groomEmail)
        || (emailMatchesCouple()
            && request.auth.uid in request.resource.data.meta.ownerUids
            && request.resource.data.meta.ownerUids.hasAll(resource.data.meta.ownerUids)
            && request.resource.data.meta.brideEmail == resource.data.meta.brideEmail
            && request.resource.data.meta.groomEmail == resource.data.meta.groomEmail);

      allow delete: if isAdmin();

      // ─── auditLog: append-only ────────────────────────────────────────
      // Read/create gated on parent-wedding ownership (checked via get()).
      // Never updatable or deletable — audit integrity.
      match /auditLog/{logId} {
        allow read: if isAdmin()
          || (isSignedIn()
              && request.auth.uid in
                 get(/databases/$(database)/documents/weddings/$(weddingId)).data.meta.ownerUids);

        allow create: if (
            isAdmin()
            || (isSignedIn()
                && request.auth.uid in
                   get(/databases/$(database)/documents/weddings/$(weddingId)).data.meta.ownerUids)
          )
          && request.resource.data.editedBy == request.auth.uid;

        allow update, delete: if false;
      }
    }

    // ───── Default deny ─────────────────────────────────────────────────
    // Anything not matched above is denied. Keep this LAST.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
