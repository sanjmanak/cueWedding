# Firebase Configuration
# Copy this file to .env and fill in your Firebase project values.
# Get these from: Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional: Explicit URL used in Firebase email-link actionCodeSettings.url
# Useful when your runtime origin (for example *.web.app) is not in Firebase Auth authorized domains.
# Example: VITE_AUTH_EMAIL_LINK_URL=https://cue-wedding.firebaseapp.com/
# VITE_AUTH_EMAIL_LINK_URL=

# Optional: Set to 'true' to use Firebase emulators for local development
# VITE_USE_FIREBASE_EMULATORS=true
